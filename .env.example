# flyto-core local configuration example.
# Copy to .env for local development only. Do not commit real tokens.

# Runtime profile: local, test, production.
FLYTO_ENV=local
LOG_LEVEL=INFO

# CLI/API integration. Leave blank unless using flyto template/cloud commands.
FLYTO_API_URL=https://api.flyto2.com
FLYTO_TOKEN=

# MCP/browser safety. Localhost and private-network access are opt-in.
FLYTO_MCP_ALLOW_LOCALHOST=0
FLYTO_ALLOWED_HOSTS=
FLYTO_ALLOW_PRIVATE_NETWORK=false

# Module exposure controls for self-hosted or enterprise deployments.
FLYTO_MODULE_ALLOWLIST=
FLYTO_MODULE_DENYLIST=
FLYTO_GRANTED_PERMISSIONS=

# Sandboxed exec defaults to a scrubbed environment. Set only in trusted labs.
FLYTO_SANDBOX_INHERIT_ENV=0
FLYTO_ALLOW_CLIENT_DB_DSN=0

# Local storage for modules such as storage.kv.
FLYTO_STORAGE_DIR=.flyto/storage

# Optional AI providers. Prefer runtime secrets or a vault in production.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
AZURE_OPENAI_API_KEY=

# Optional vector search provider.
QDRANT_MODE=local
QDRANT_PATH=.flyto/qdrant_storage
QDRANT_URL=
QDRANT_API_KEY=

# Optional search provider.
TAVILY_API_KEY=

# Optional connector credentials. Keep blank in committed examples.
GITHUB_TOKEN=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Optional cloud/storage connectors.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# Optional enterprise/offline behavior.
FLYTO_OFFLINE_MODE=false
FLYTO_ALLOW_REMOTE_OLLAMA=false
OLLAMA_API_URL=http://localhost:11434
